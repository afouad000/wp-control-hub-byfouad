# -----------------------------------------------------------------------------
# WP Control Hub — environment variables (example)
# -----------------------------------------------------------------------------
# On Lovable Cloud the real .env is provisioned automatically and is NOT
# committed to the repo. Copy this file to `.env` for local development and
# fill in the values from your Lovable Cloud project (Backend → Settings).
#
# NEVER commit a real .env. NEVER put SUPABASE_SERVICE_ROLE_KEY or any
# WordPress / WooCommerce credentials in a VITE_* variable — VITE_* is
# shipped to the browser bundle.
# -----------------------------------------------------------------------------

# --- Public (safe to expose to the browser) ---
# Supabase project URL and publishable/anon key. Used by the client SDK.
VITE_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# --- Server-only (available to server functions via process.env) ---
# Mirror of the public values, read by SSR / server functions.
SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
SUPABASE_PROJECT_ID="your-project-ref"

# SECRET — service role key. Bypasses RLS. Server-only. Never expose.
# On Lovable Cloud this is injected automatically and is not readable
# from the dashboard. Leave blank locally unless you need admin ops.
SUPABASE_SERVICE_ROLE_KEY=""

# SECRET — Lovable AI Gateway key, used by server functions calling the
# gateway (e.g. WooCommerce connector). Provisioned by Lovable Cloud.
LOVABLE_API_KEY=""
